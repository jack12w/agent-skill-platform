# Production Environment Variables
# 部署到宝塔 Docker 时，将这些变量填入宝塔 → Docker → 环境变量，或创建此文件后 docker compose 自动读取

# 网站域名
PUBLIC_BASE_URL=website-url

# 阿里云 RDS PostgreSQL
DB_HOST=pgm-xxxxxxxx.pgsql.cn-chengdu.rds.aliyuncs.com
DB_PORT=5432
DB_USER=usXXX31
DB_PASSWORD=your_password
DB_NAME=platform
DB_SSL=false

# JWT 密钥（生产环境务必更换为强随机字符串）
JWT_SECRET=change-me-to-a-random-string

# 阿里云 OSS
OSS_REGION=oss-cn-beijing
OSS_BUCKET=zhXXXnt
OSS_ACCESS_KEY_ID=your_key_id
OSS_ACCESS_KEY_SECRET=your_key_secret
OSS_PUBLIC_HOST=zXXX-agent.oss-cn-beijing.aliyuncs.com

# SMTP 邮箱配置（用于发送验证码）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_auth_code

# Redis（邮件队列 Bull 后端，默认指向 compose 内 redis 服务，一般无需修改）
REDIS_URL=redis://redis:6379

# 微信开放平台（网站应用）
# WECHAT_LOGIN_ENABLED 为总开关：同时控制前端登录按钮显隐 + 后端微信链路断言；上线改为 true
WECHAT_LOGIN_ENABLED=false
WECHAT_APPID=wxb2XXXX6a7
WECHAT_APPSECRET=your_wechat_app_secret
# 微信登录回调地址（必须与开放平台"授权回调域名"一致且为 https）；本地是 localhost，上线必须改
WECHAT_REDIRECT_URI=https://website-url/api/auth/wechat/callback

# ──────────────────────────────────────────────
# 微信支付（后续阶段接入，当前代码未使用下列字段，先预留）
# 注意：支付用 AppID 与上方登录 AppID 是两套、不可混用
# ──────────────────────────────────────────────
# 商户模式（自己收款）：在微信支付商户平台 pay.weixin.qq.com 申请商户号
WECHAT_PAY_MCHID=your_mch_id
WECHAT_PAY_APPID=your_pay_appid                     # 支付用 AppID（公众号服务号/移动应用），≠ 登录 AppID
WECHAT_PAY_APIV3_KEY=your_apiv3_key                 # APIv3 密钥（回调解密用）
WECHAT_PAY_CERT_SERIAL_NO=your_cert_serial          # 商户 API 证书序列号
WECHAT_PAY_CERT_PATH=/app/certs/apiclient_cert.pem   # 商户证书公钥（compose 挂载进 api 容器）
WECHAT_PAY_KEY_PATH=/app/certs/apiclient_key.pem     # 商户证书私钥（签名用，不可外泄）
WECHAT_PAY_PUBLIC_KEY_PATH=/app/certs/wxp_pub.pem    # 微信支付公钥（验签用）
WECHAT_PAY_NOTIFY_URL=https://website-url/api/pay/notify   # 支付结果回调（需 https、域名已备案）
