# ── Stage 1: Build ──────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/api/package.json packages/api/
COPY packages/api/tsconfig.json packages/api/
COPY packages/shared/package.json packages/shared/
COPY packages/shared/tsconfig.json packages/shared/

# bcrypt 需要原生编译（Alpine 缺 Python/make/g++）
RUN apk add --no-cache python3 make g++

RUN npm config set registry https://registry.npmmirror.com \
  && npm ci --legacy-peer-deps \
  && npm install -g typescript@5.9.3

COPY packages/shared/src packages/shared/src
COPY packages/api/src packages/api/src

# Force tsc recompilation — set BUILD_DATE env var to invalidate cache
ARG BUILD_DATE=0
RUN echo "tsc compile at ${BUILD_DATE}"

RUN tsc -p packages/shared/tsconfig.json
RUN tsc -p packages/api/tsconfig.json

# ── Stage 2: Production ─────────────────────────
FROM node:20-alpine

WORKDIR /app

# 生产依赖（仅运行时需要的）
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages/api/package.json ./

# 构建产物
COPY --from=builder /app/packages/api/dist ./dist
COPY --from=builder /app/packages/shared/dist ./packages/shared/dist
COPY --from=builder /app/packages/shared/package.json ./packages/shared/

# workspace 软链接在 COPY 时丢失，手动创建 @platform/shared 映射
RUN mkdir -p node_modules/@platform
RUN echo '{"name":"@platform/shared","main":"../../../packages/shared/dist/index.js","types":"../../../packages/shared/dist/index.d.ts"}' > node_modules/@platform/shared/package.json

ENV NODE_ENV=production
ENV PORT=3001

EXPOSE 3001

CMD ["node", "dist/main.js"]
