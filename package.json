{
  "name": "agent-skill-platform",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "npm run dev --workspace=@platform/api",
    "build:shared": "npm run build --workspace=@platform/shared",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "start:prod": "pm2 start ecosystem.config.js",
    "stop:prod": "pm2 stop ecosystem.config.js",
    "reload:prod": "pm2 reload ecosystem.config.js",
    "logs:prod": "pm2 logs api",
    "status:prod": "pm2 status"
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.0.0",
    "pm2": "^5.4.0",
    "typescript": "^5.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  }
}
